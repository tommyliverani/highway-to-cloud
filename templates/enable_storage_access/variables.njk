{# old values #}
{% for key, value in values %}
{{ key }}: {{ value }}
{% endfor %}
inline_policy_statements:
  - Sid: "S3BucketListAndLocation"
    Effect: "Allow"
    Action:
      - "s3:ListBucket"
      - "s3:GetBucketLocation"
    Resource: 
      - "arn:aws:s3:::{{ parameters.storage_name }}"

  - Sid: "S3BucketObjectAccess"
    Effect: "Allow"
    Action:
      - "s3:GetObject"
      - "s3:GetObjectVersion"
      - "s3:PutObject"
      - "s3:PutObjectAcl"
      - "s3:DeleteObject"
      - "s3:DeleteObjectVersion"
    Resource: 
      - "arn:aws:s3:::{{ parameters.storage_name }}/*"